{
  "mcpServers": {
    "fast-filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "fast-filesystem-mcp@latest"],
      "env": {
        "MCP_SILENT_ERRORS": "true"
      }
    },
    "octocode": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "octocode-mcp@latest"],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN",
        "ENABLE_LOCAL": "true",
        "LOG": "false"
      }
    },
    "ast-grep": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@notprolands/ast-grep-mcp@latest"]
    },
    "ref-tools": {
      "type": "http",
      "url": "https://api.ref.tools/mcp"
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=claude-code",
        "--project-from-cwd"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "@upstash/context7-mcp"]
    }
  }
}
