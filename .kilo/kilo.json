{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    ".kilo/rules/*.md",
    "https://raw.githubusercontent.com/JRedeker/opencode-shell-strategy/trunk/shell_strategy.md"
  ],
  "skills": {
    "paths": [".kilo/skill", ".opencode/skill", ".claude/skills"]
  },
  "permission": {
    "*": "allow",
    "edit": { "dist/**": "deny", "*.lock": "deny", "*": "allow" },
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&};:": "deny",
    "doom_loop": "deny"
  },
  "disabled_providers": ["openai"],
  "plugin": [
    "openslimedit@1.0.4",
    "opencode-ignore@1.1.0",
    "@gotgenes/opencode-agent-identity@3.0.1",
    "opencode-websearch@0.5.0"
  ],
  "formatter": {
    "biome": {
      "command": ["npx", "-y", "@biomejs/biome", "check", "--write", "--format-with-errors=true", "$FILE"],
      "extensions": [".json", ".js"]
    }
  },
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", ".venv/**", "__pycache__/**", ".ruff_cache/**"] },
  "mcp": {
    "ref-tools": {
      "type": "remote",
      "url": "https://api.ref.tools/mcp",
      "enabled": true,
      "headers": { "x-ref-api-key": "{env:REF_API_KEY}" },
      "oauth": false
    },
    "github-mcp-server": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa",
      "enabled": true,
      "headers": { "x-api-key": "{env:EXA_API_KEY}" },
      "oauth": false
    },
    "git-mcp": {
      "type": "remote",
      "url": "https://gitmcp.io/Ven0m0/arc-raiders-autoscrapper",
      "enabled": true
    }
  },
  "lsp": {
    "pyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyw", ".pyi"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "json-ls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "tombi": {
      "command": ["tombi", "lsp"],
      "extensions": [".toml"]
    }
  },
  "compaction": { "auto": true, "prune": true },
  "experimental": {
    "continue_loop_on_deny": false,
    "codebase_search": true,
    "mcp_timeout": 30000,
    "openTelemetry": false,
    "batch_tool": true
  }
}
