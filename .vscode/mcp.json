{
  "servers": {
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "X-MCP-Toolsets": "default,actions,code_security,copilot,git,github_support_docs_search,stargazers,dependabot"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com/mcp"
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,crawling_exa",
      "headers": {
        "EXA_API_KEY": "$EXA_API_KEY"
      }
    },
    "ref-tools": {
      "type": "http",
      "url": "https://api.ref.tools/mcp",
      "headers": {
        "x-ref-api-key": "$REF_API_KEY"
      }
    },
    "fast-filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "fast-filesystem-mcp@latest"
      ],
      "env": {
        "MCP_SILENT_ERRORS": "true"
      }
    },
    "octocode": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "octocode-mcp@latest"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN",
        "ENABLE_LOCAL": "true",
        "LOG": "false"
      }
    }
  }
}
