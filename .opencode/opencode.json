{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../AGENTS.md"],
  "permission": {
    "*": "allow",
    "sudo *": "deny",
    "rm -rf /": "deny",
    "rm -rf /*": "deny",
    "rm -rf ~": "deny",
    "rm -rf ~/*": "deny",
    ":(){:|:&}:": "deny",
    "doom_loop": "deny"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".venv/**",
      "uv.lock",
      "ocr_debug/**",
      ".omc/**",
      ".claude/worktrees/**",
      ".ruff_cache/**",
      "__pycache__/**",
      "**/__pycache__/**",
      "**/node_modules/**",
      "src/autoscrapper/progress/data/**",
      "src/autoscrapper/items/items_rules.default.json"
    ]
  },
  "experimental": {
    "continue_loop_on_deny": false,
    "batch_tool": true
  },
  "mcp": {
    "git-mcp": {
      "type": "remote",
      "url": "https://gitmcp.io/Ven0m0/arc-raiders-autoscrapper"
    }
  }
}
