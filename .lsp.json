{
  "$schema": "https://json.schemastore.org/schema.json",
  "languages": {
    "python": {
      "command": "basedpyright-langserver",
      "args": ["--stdio"],
      "initializationOptions": {
        "pythonVersion": "3.13"
      }
    },
    "bash": {
      "command": "bash-language-server",
      "args": ["start"]
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": ["--stdio"]
    },
    "json": {
      "command": "json-language-server",
      "args": ["--stdio"]
    },
    "toml": {
      "command": "taplo",
      "args": ["lsp", "stdio"]
    },
    "typescript": {
      "command": "vtsls",
      "args": ["--stdio"]
    },
    "javascript": {
      "command": "vtsls",
      "args": ["--stdio"]
    }
  }
}
